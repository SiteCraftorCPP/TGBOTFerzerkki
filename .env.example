TELEGRAM_BOT_TOKEN=
# Несколько админов: только числовые Telegram user id через запятую (можно перенос строки или ;).
# Узнать id: @userinfobot / Raw Data в клиенте. Пример:
# ADMIN_IDS=111111111,222222222
ADMIN_IDS=
TELEGRAM_PROXY=
DATABASE_URL=sqlite+aiosqlite:///./clashduel.db
SUBSCRIPTION_PRICE_RUB=150
DEFAULT_COMMISSION_PERCENT=15
SUBSCRIBER_COMMISSION_PERCENT=5
# Опционально: ID супергруппы с включёнными «темами» (форум). Каждое обращение в поддержку — новая ветка.
MODERATION_CHAT_ID=
# Опционально: message_thread_id ветки «Споры» — все споры падают туда. Без этого — новая подтема на каждый спор.
MODERATION_DISPUTES_THREAD_ID=

# Только SQLite: true — при старте бота удалить все обращения и сбросить номера тикетов с 1 (для теста). Потом выключи.
RESET_SUPPORT_TICKETS_ON_STARTUP=false

